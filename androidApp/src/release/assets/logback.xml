<?xml version="1.0" encoding="UTF-8"?>
<!--
  Logback Configuration for Android - RELEASE BUILD

  Production-optimized configuration:
  - Minimal logging (ERROR only)
  - File-based logging for crash analysis
  - No Logcat output in production
-->
<configuration>
    <!-- Production: Only ERROR level -->
    <property name="LOG_LEVEL" value="ERROR" />
    <property name="LOG_DIR" value="${LOG_DIR:-/data/data/com.aggregateservice/files/logs}" />

    <!-- File Appender only - for crash analysis -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/aggregate-service.log</file>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/aggregate-service.%d{yyyy-MM-dd}.log.gz</fileNamePattern>
            <maxHistory>3</maxHistory>
            <totalSizeCap>5MB</totalSizeCap>
        </rollingPolicy>
    </appender>

    <!-- Ktor - errors only -->
    <logger name="io.ktor" level="ERROR" additivity="false">
        <appender-ref ref="FILE" />
    </logger>

    <!-- Koin - errors only -->
    <logger name="org.koin" level="ERROR" additivity="false">
        <appender-ref ref="FILE" />
    </logger>

    <!-- Application Logger - errors only -->
    <logger name="com.aggregateservice" level="ERROR" additivity="false">
        <appender-ref ref="FILE" />
    </logger>

    <!-- Root Logger - errors only -->
    <root level="ERROR">
        <appender-ref ref="FILE" />
    </root>
</configuration>
